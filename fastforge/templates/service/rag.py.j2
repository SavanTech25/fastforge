import os
{% if provider in ['openai', 'azure'] %}
from langchain_openai import ChatOpenAI, OpenAIEmbeddings
{% elif provider == 'anthropic' %}
from langchain_anthropic import ChatAnthropic
# Note: Anthropic doesn't have an official embedding model natively in Langchain, mock fallback:
from langchain_community.embeddings import FakeEmbeddings as Embeddings
{% elif provider == 'mistral' %}
from langchain_mistralai import ChatMistralAI, MistralAIEmbeddings
{% elif provider == 'gemini' %}
from langchain_google_genai import ChatGoogleGenerativeAI, GoogleGenerativeAIEmbeddings
{% endif %}
from langchain.prompts import PromptTemplate
from langchain_core.runnables import RunnablePassthrough
from langchain_core.output_parsers import StrOutputParser

class {{ service_name }}Service:
    def __init__(self):
        {% if provider == 'openai' %}
        self.llm = ChatOpenAI(model="gpt-4o", temperature=0)
        self.embeddings = OpenAIEmbeddings()
        {% elif provider == 'azure' %}
        self.llm = ChatOpenAI(model="gpt-4o", temperature=0, azure_deployment="gpt-4o", api_version="2024-02-15-preview")
        self.embeddings = OpenAIEmbeddings(azure_deployment="text-embedding-3-small", api_version="2024-02-15-preview")
        {% elif provider == 'anthropic' %}
        self.llm = ChatAnthropic(model="claude-3-5-sonnet-20240620", temperature=0)
        self.embeddings = Embeddings(size=1536) # Replace with your embedding provider
        {% elif provider == 'mistral' %}
        self.llm = ChatMistralAI(model="mistral-large-latest", temperature=0)
        self.embeddings = MistralAIEmbeddings()
        {% elif provider == 'gemini' %}
        self.llm = ChatGoogleGenerativeAI(model="gemini-1.5-pro", temperature=0)
        self.embeddings = GoogleGenerativeAIEmbeddings(model="models/embedding-001")
        {% endif %}
        
        # =====================================================================
        # VECTOR STORE SETUP
        # =====================================================================
        {% if vector_store == 'chroma' %}
        from langchain_chroma import Chroma
        self.vector_store = Chroma(
            collection_name="rag_collection",
            embedding_function=self.embeddings,
            persist_directory="./chroma_data"
        )
        {% elif vector_store == 'qdrant' %}
        from langchain_qdrant import QdrantVectorStore
        from qdrant_client import QdrantClient
        client = QdrantClient(url=config("QDRANT_URL"), api_key=config("QDRANT_API_KEY"))
        self.vector_store = QdrantVectorStore(
            client=client,
            collection_name="rag_collection",
            embedding=self.embeddings
        )
        {% elif vector_store == 'supabase' %}
        from langchain_postgres import PGVector
        self.vector_store = PGVector(
            embeddings=self.embeddings,
            collection_name="rag_collection",
            connection=config("SUPABASE_DB_URL"),
            use_jsonb=True,
        )
        {% endif %}
        
    def _retrieve_context(self, query: str) -> str:
        docs = self.vector_store.similarity_search(query, k=3)
        return "\n\n".join([doc.page_content for doc in docs])

    async def invoke(self, query: str, session_id: str = None) -> str:
        template = """Answer the question based only on the following context:
        {context}
        
        Question: {question}
        """
        prompt = PromptTemplate.from_template(template)
        
        chain = (
            {"context": lambda q: self._retrieve_context(q), "question": RunnablePassthrough()}
            | prompt
            | self.llm
            | StrOutputParser()
        )
        
        return await chain.ainvoke(query)
