from decouple import config
import base64
import json
{% if provider in ['openai', 'azure'] %}
from openai import AsyncOpenAI{% if provider == 'azure' %}, AsyncAzureOpenAI{% endif %}
{% elif provider == 'anthropic' %}
from anthropic import AsyncAnthropic
{% elif provider == 'mistral' %}
from mistralai.async_client import MistralAsyncClient
{% elif provider == 'gemini' %}
from google import genai
{% endif %}

class {{ service_name }}Service:
    def __init__(self):
        {% if provider == 'openai' %}
        self.client = AsyncOpenAI(api_key=config("OPENAI_API_KEY"))
        self.model = "gpt-4o"
        {% elif provider == 'azure' %}
        self.client = AsyncAzureOpenAI(
            api_key=config("AZURE_OPENAI_API_KEY"),
            api_version="2024-02-15-preview",
            azure_endpoint=config("AZURE_OPENAI_ENDPOINT")
        )
        self.model = config("AZURE_OPENAI_VISION_DEPLOYMENT", default="gpt-4o")
        {% elif provider == 'anthropic' %}
        self.client = AsyncAnthropic(api_key=config("ANTHROPIC_API_KEY"))
        self.model = "claude-3-5-sonnet-20240620"
        {% elif provider == 'mistral' %}
        self.client = MistralAsyncClient(api_key=config("MISTRAL_API_KEY"))
        self.model = "pixtral-12b-2409"
        {% elif provider == 'gemini' %}
        self.client = genai.Client(api_key=config("GEMINI_API_KEY"))
        self.model = "gemini-1.5-pro"
        {% endif %}

    def _encode_image(self, file_path: str) -> str:
        with open(file_path, "rb") as image_file:
            return base64.b64encode(image_file.read()).decode('utf-8')

    async def extract_text(self, file_path_or_url: str) -> dict:
        """
        Extract structured text from an image or document using Vision capabilities.
        """
        prompt = "Extract all the text from this image and return it as structured JSON."
        
        is_url = file_path_or_url.startswith("http")
        base64_image = None if not is_url else None
        if not is_url:
            base64_image = self._encode_image(file_path_or_url)
        
        {% if provider in ['openai', 'azure'] %}
        image_url = file_path_or_url if is_url else f"data:image/jpeg;base64,{base64_image}"
        response = await self.client.chat.completions.create(
            model=self.model,
            response_format={"type": "json_object"},
            messages=[
                {
                    "role": "user",
                    "content": [
                        {"type": "text", "text": prompt},
                        {"type": "image_url", "image_url": {"url": image_url}}
                    ]
                }
            ]
        )
        return json.loads(response.choices[0].message.content)
        {% elif provider == 'anthropic' %}
        content = [{"type": "text", "text": prompt}]
        if not is_url:
            content.append({
                "type": "image",
                "source": {
                    "type": "base64",
                    "media_type": "image/jpeg",
                    "data": base64_image
                }
            })
        else:
            # Note: Anthropic Python SDK natively requires base64 images
            raise ValueError("Anthropic requires base64 images, URLs are not directly supported without downloading.")
            
        response = await self.client.messages.create(
            model=self.model,
            max_tokens=1024,
            messages=[{"role": "user", "content": content}]
        )
        return {"text": response.content[0].text}
        {% elif provider == 'mistral' %}
        image_url = file_path_or_url if is_url else f"data:image/jpeg;base64,{base64_image}"
        response = await self.client.chat(
            model=self.model,
            messages=[
                {
                    "role": "user",
                    "content": [
                        {"type": "text", "text": prompt},
                        {"type": "image_url", "image_url": image_url}
                    ]
                }
            ]
        )
        return {"text": response.choices[0].message.content}
        {% elif provider == 'gemini' %}
        # Minimal gemini vision snippet
        response = self.client.models.generate_content(
            model=self.model,
            contents=[prompt, file_path_or_url if is_url else file_path_or_url]
        )
        return {"text": response.text}
        {% endif %}
