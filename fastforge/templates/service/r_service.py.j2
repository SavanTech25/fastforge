from fastapi import APIRouter, Depends, HTTPException
from pydantic import BaseModel
from {{ project_name }}.service.{{ service_name_lower }} import {{ service_name }}Service
from {{ project_name }}.middleware.middleware import JWTBearer

r_{{ service_name_lower }} = APIRouter(prefix="/{{ service_name_lower }}", tags=["{{ service_name }}"])

class {{ service_name }}Request(BaseModel):
{% if service_type == 'ocr' %}
    file_path_or_url: str
{% else %}
    query: str
    session_id: str | None = None
{% endif %}

@r_{{ service_name_lower }}.post("", dependencies=[Depends(JWTBearer())])
async def execute_{{ service_name_lower }}(req: {{ service_name }}Request):
    try:
        service = {{ service_name }}Service()
        {% if service_type == 'ocr' %}
        result = await service.extract_text(req.file_path_or_url)
        {% else %}
        result = await service.invoke(req.query, req.session_id)
        {% endif %}
        return {"status": "success", "data": result}
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))
