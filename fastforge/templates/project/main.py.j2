from fastapi import FastAPI
from contextlib import asynccontextmanager

{% if db != "mongodb" %}
from {{ project_name|lower }}.data.database import Base, engine

Base.metadata.create_all(bind=engine)
{% else %}
from {{ project_name|lower }}.data.database import connect_to_mongo, close_mongo_connection
{% endif %}
from {{ project_name|lower }}.utils.limiter import setup_limiter
from {{ project_name|lower }}.utils.scheduling import start_scheduler, stop_scheduler

@asynccontextmanager
async def lifespan(app: FastAPI):
    # Startup actions
    start_scheduler()
    {% if db == "mongodb" %}
    await connect_to_mongo()
    {% endif %}
    yield
    # Shutdown actions
    stop_scheduler()
    {% if db == "mongodb" %}
    await close_mongo_connection()
    {% endif %}

app = FastAPI(title="{{ project_name }}", description="Generated by FastForge ⚡", version="0.1.0", lifespan=lifespan)

setup_limiter(app)

# from {{ project_name|lower }}.router import user
# app.include_router(user.router)

@app.get("/")
def root():
    return {"message": "Welcome to {{ project_name }}"}
