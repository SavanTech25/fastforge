from fastapi import FastAPI
{% if db != "mongodb" %}
from {{ project_name|lower }}.data.database import Base, engine

Base.metadata.create_all(bind=engine)
{% else %}
from {{ project_name|lower }}.data.database import connect_to_mongo, close_mongo_connection
{% endif %}
from {{ project_name|lower }}.utils.limiter import setup_limiter
from {{ project_name|lower }}.utils.scheduling import start_scheduler, stop_scheduler

app = FastAPI(title="{{ project_name }}", description="Generated by FastForge ⚡", version="0.1.0")

setup_limiter(app)

@app.on_event("startup")
async def startup_event():
    start_scheduler()
    {% if db == "mongodb" %}
    await connect_to_mongo()
    {% endif %}

@app.on_event("shutdown")
async def shutdown_event():
    stop_scheduler()
    {% if db == "mongodb" %}
    await close_mongo_connection()
    {% endif %}

