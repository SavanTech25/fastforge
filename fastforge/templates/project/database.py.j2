{% if db == "mongodb" %}
from motor.motor_asyncio import AsyncIOMotorClient
from decouple import config

class DataBase:
    client: AsyncIOMotorClient = None

async def connect_to_mongo():
    DataBase.client = AsyncIOMotorClient(config("DATABASE_URL", default="mongodb://localhost:27017/dbname"))

async def close_mongo_connection():
    if DataBase.client:
        DataBase.client.close()

async def get_db():
    db_name = config("DB_NAME", default="")
    if db_name:
        return DataBase.client[db_name]

    # Fallback to extracting from URL
    database_url = config("DATABASE_URL", default="mongodb://localhost:27017/fastforge_db")
    path_part = database_url.split("?")[0]
    db_name = path_part.split("/")[-1] or "fastforge_db"
    return DataBase.client[db_name]
{% else %}
from sqlalchemy import create_engine
from sqlalchemy.ext.declarative import declarative_base
from sqlalchemy.orm import sessionmaker
from decouple import config

engine = create_engine(
    config("DATABASE_URL", default="{{ db_url }}"),
    {% if db == "sqlite" %}connect_args={"check_same_thread": False}{% endif %}
)
SessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=engine)
Base = declarative_base()

def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()
{% endif %}
