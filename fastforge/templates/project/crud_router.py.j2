from fastapi import APIRouter, Depends, BackgroundTasks
{% if db == "mongodb" %}
from bson.objectid import ObjectId
{% else %}
from sqlalchemy.orm import Session
from {{ project_name|lower }}.data.database import get_db
{% endif %}
from {{ project_name|lower }}.middleware.middleware import JWTBearer
from fastapi_cache.decorator import cache
from fastapi import HTTPException

def http_error(detail: str, status_code: int = 400):
    raise HTTPException(status_code=status_code, detail=detail)

def create_crud_router(entity_class, model_class, prefix: str):

    router = APIRouter(prefix=f"/{prefix}", tags=[prefix])

    @router.post("", dependencies=[Depends(JWTBearer())])
    async def create(data: model_class, background_tasks: BackgroundTasks, {% if db != "mongodb" %}db: Session = Depends(get_db){% endif %}):
        try:
            model = entity_class()
            {% if db != "mongodb" %}model.setDb(db){% endif %}
            model.load(data)
            res = model.save()
            {% if db == "mongodb" %}
            if res and res.inserted_id:
                return {"message": f"{prefix} créé avec succès", "state": "success"}
            {% else %}
            if res:
                return {"message": f"{prefix} créé avec succès", "state": "success"}
            {% endif %}
            return {"message": f"{prefix} non sauvegardé", "state": "warning"}
        except Exception as e:
            http_error(str(e), 400)

    @router.get("/{id}", dependencies=[Depends(JWTBearer())])
    @cache(expire=60)
    async def get_one(id: str, {% if db != "mongodb" %}db: Session = Depends(get_db){% endif %}):
        try:
            model = entity_class()
            {% if db != "mongodb" %}model.setDb(db){% endif %}
            result = model.getById(id)
            if not result:
                return {"message": f"{prefix} introuvable", "state": "warning"}
            return {prefix: result}
        except Exception as e:
            http_error(str(e), 400)

    @router.get("", dependencies=[Depends(JWTBearer())])
    @cache(expire=60)
    async def get_all({% if db != "mongodb" %}db: Session = Depends(get_db){% endif %}):
        try:
            model = entity_class()
            {% if db != "mongodb" %}model.setDb(db){% endif %}
            return {f"{prefix}s": model.getAll()}
        except Exception as e:
            http_error(str(e), 400)

    @router.put("/{id}", dependencies=[Depends(JWTBearer())])
    async def update(id: str, data: model_class, {% if db != "mongodb" %}db: Session = Depends(get_db){% endif %}):
        try:
            model = entity_class()
            {% if db != "mongodb" %}model.setDb(db){% endif %}
            model.load(data)
            {% if db == "mongodb" %}
            model.setId(ObjectId(id))
            {% else %}
            model.setId(id)
            {% endif %}
            res = model.update()
            {% if db == "mongodb" %}
            if res and res.modified_count > 0:
                return {"message": f"{prefix} mis à jour", "state": "success"}
            {% else %}
            if res:
                return {"message": f"{prefix} mis à jour", "state": "success"}
            {% endif %}
            return {"message": "rien a changé", "state": "warning"}
        except Exception as e:
            http_error(str(e), 400)

    @router.delete("/{id}", dependencies=[Depends(JWTBearer())])
    async def delete(id: str, background_tasks: BackgroundTasks, {% if db != "mongodb" %}db: Session = Depends(get_db){% endif %}):
        try:
            model = entity_class()
            {% if db != "mongodb" %}model.setDb(db){% endif %}
            {% if db == "mongodb" %}
            model.setId(ObjectId(id))
            {% else %}
            model.setId(id)
            {% endif %}
            res = model.delete()
            {% if db == "mongodb" %}
            if res and res.deleted_count > 0:
                return {"message": f"{prefix} supprimé", "state": "success"}
            {% else %}
            if res:
                return {"message": f"{prefix} supprimé", "state": "success"}
            {% endif %}
            return {"message": f"{prefix} non supprimé", "state": "warning"}
        except Exception as e:
            http_error(str(e), 400)

    return router
