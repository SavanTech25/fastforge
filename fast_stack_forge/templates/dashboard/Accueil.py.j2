</style>
""", unsafe_allow_html=True)

st.markdown("""
<div class="hero-card">
    <div class="hero-title">🧠 {{ project_name | title }}</div>
    <div class="hero-sub">
        Powered by FastForge ⚡ · FastAPI · dbt · Streamlit
    </div>
</div>
""", unsafe_allow_html=True)

cards = [
{% for page in pages %}
    ("{{ page.icon }}", "{{ page.title }}", "{{ page.description }}"),
{% endfor %}
]

cols = st.columns(len(cards)) if cards else []
for col, (icon, title, desc) in zip(cols, cards):
    with col:
        st.markdown(f"""
        <div class="nav-card">
            <div class="nav-icon">{icon}</div>
            <div class="nav-title">{title}</div>
            <div class="nav-desc">{desc}</div>
        </div>""", unsafe_allow_html=True)

st.markdown("<br>", unsafe_allow_html=True)
st.info("👈 Select a page from the sidebar to get started.", icon="💡")
