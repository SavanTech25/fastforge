      background: linear-gradient(180deg,#0f0f1a,#1a1a2e);
      border-right: 1px solid #2d2d4e;
  }
  section[data-testid="stSidebar"] * { color: #e0e0f5 !important; }
  .stApp { background: #0d0d1a; color: #e0e0f5; }
  .hero-card {
      background: linear-gradient(135deg,#1e1b4b,#312e81,#1e40af);
      border-radius: 20px; padding: 50px 40px; margin-bottom: 30px;
      border: 1px solid rgba(99,102,241,0.3);
      box-shadow: 0 0 60px rgba(99,102,241,0.15);
  }
  .hero-title {
      font-size: 2.8rem; font-weight: 700;
