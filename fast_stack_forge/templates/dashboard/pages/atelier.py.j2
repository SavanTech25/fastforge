def run_cmd(cmd: list[str], cwd: Path) -> tuple[bool, str]:
    try:
        r = subprocess.run(cmd, cwd=str(cwd), capture_output=True, text=True, timeout=60)
        return r.returncode == 0, r.stdout + r.stderr
    except Exception as e:
        return False, str(e)


def list_entities() -> list[str]:
    d = SRC_DIR / "entity"
    return [f.stem for f in d.glob("*.py") if f.stem not in ("__init__", "base_entity")] if d.exists() else []


def list_services() -> list[str]:
    d = SRC_DIR / "service"
    return [f.stem for f in d.glob("*.py") if f.stem != "__init__"] if d.exists() else []


st.markdown("# 🏗️ Atelier FastForge")
st.markdown("Scaffold, manage and remove entities, services and dbt models — all from the UI.")
st.divider()

# ── ENTITIES ──────────────────────────────────────────────────────────────────
st.markdown("## Entities")
col_left, col_right = st.columns(2, gap="large")

with col_left:
    st.markdown('<div class="panel"><div class="panel-title">➕ Create Entity</div>', unsafe_allow_html=True)
    entity_name = st.text_input("Entity name", placeholder="Post, Comment, User…", key="ent_name")
    st.caption("Fields — format: `name:type` or `name:type:hash`. Types: string, int, float, bool, text, date")
    fields_raw  = st.text_area("Fields (one per line)", height=130, key="ent_fields")
    rag_service = st.checkbox("Also scaffold a RAG service", key="rag_svc")
    if st.button("⚡ Generate Entity", type="primary", width="stretch", key="gen_entity"):
        if not entity_name.strip():
            st.error("Entity name is required.")
        else:
            fields = [f.strip() for f in fields_raw.strip().splitlines() if f.strip()]
            ok, out = run_cmd(["fast-stack-forge", "make:entity", entity_name] + fields, PROJECT_ROOT)
            st.markdown(f'<div class="cmd-output">{out}</div>', unsafe_allow_html=True)
            if ok:
                st.success(f"✔ Entity `{entity_name}` created!")
            if rag_service:
                ok2, out2 = run_cmd(["fast-stack-forge", "make:service", entity_name, "--rag"], PROJECT_ROOT)
                st.markdown(f'<div class="cmd-output">{"✔" if ok2 else "⚠"} RAG Service:\n{out2}</div>', unsafe_allow_html=True)
    st.markdown("</div>", unsafe_allow_html=True)

with col_right:
    st.markdown('<div class="panel"><div class="panel-title">🗑️ Remove Entity</div>', unsafe_allow_html=True)
    entities = list_entities()
    for e in entities:
        has_svc = (SRC_DIR / "service" / f"{e.lower()}.py").exists()
        st.markdown(
            f'<span class="badge badge-entity">{e}</span>'
            + ('<span class="badge badge-service">service</span>' if has_svc else ""),
            unsafe_allow_html=True,
        )
    if not entities:
        st.info("No entities found.")
    discard_name = st.selectbox("Select entity to remove", [""] + entities, key="discard_sel")
    confirm_del  = st.checkbox("I confirm I want to remove this entity", key="confirm_del")
    if st.button("🗑 Remove Entity", type="secondary", width="stretch", key="rm_entity"):
        if not discard_name:
            st.error("Select an entity first.")
        elif not confirm_del:
            st.warning("Please confirm before removing.")
        else:
            ok, out = run_cmd(["fast-stack-forge", "make:discard", discard_name], PROJECT_ROOT)
            st.markdown(f'<div class="cmd-output">{out}</div>', unsafe_allow_html=True)
            if ok:
                st.success(f"✔ Entity `{discard_name}` removed!")
    st.markdown("</div>", unsafe_allow_html=True)

# ── SERVICES ──────────────────────────────────────────────────────────────────
st.divider()
st.markdown("## Services")
col_s1, col_s2 = st.columns(2, gap="large")

with col_s1:
    st.markdown('<div class="panel"><div class="panel-title">⚙️ Create Service</div>', unsafe_allow_html=True)
    svc_name = st.text_input("Service name", placeholder="Post", key="svc_name")
    svc_type = st.radio("Service type", ["standard", "rag"], horizontal=True, key="svc_type")
    if st.button("⚡ Generate Service", type="primary", width="stretch", key="gen_svc"):
        if not svc_name.strip():
            st.error("Service name required.")
        else:
            cmd = ["fast-stack-forge", "make:service", svc_name] + (["--rag"] if svc_type == "rag" else [])
            ok, out = run_cmd(cmd, PROJECT_ROOT)
            st.markdown(f'<div class="cmd-output">{out}</div>', unsafe_allow_html=True)
            if ok:
                st.success(f"✔ Service `{svc_name}` created!")
    st.markdown("</div>", unsafe_allow_html=True)

with col_s2:
    st.markdown('<div class="panel"><div class="panel-title">📋 Existing Services</div>', unsafe_allow_html=True)
    for s in list_services():
        st.markdown(f'<span class="badge badge-service">{s}</span>', unsafe_allow_html=True)
    if not list_services():
        st.info("No services found.")
    st.markdown("</div>", unsafe_allow_html=True)

# ── DBT ───────────────────────────────────────────────────────────────────────
st.divider()
st.markdown("## dbt Pipeline")

dbt_cmds = {
    "▶ dbt run":                 ["dbt", "run"],
    "🔄 dbt run --full-refresh": ["dbt", "run", "--full-refresh"],
    "🧪 dbt test":               ["dbt", "test"],
    "📦 dbt deps":               ["dbt", "deps"],
    "🌱 dbt seed":               ["dbt", "seed"],
    "💡 dbt compile":            ["dbt", "compile"],
}
cols = st.columns(3, gap="medium")
for i, (label, cmd) in enumerate(dbt_cmds.items()):
    with cols[i % 3]:
        if st.button(label, width="stretch", key=f"dbt_{i}"):
            with st.spinner(f"Running `{' '.join(cmd)}`…"):
                ok, out = run_cmd(cmd, DBT_DIR)
            if ok:
                st.success("Done!")
            else:
                st.error("Command failed.")
            st.markdown(f'<div class="cmd-output">{out}</div>', unsafe_allow_html=True)
