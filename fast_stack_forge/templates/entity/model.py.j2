{% if db_type == "mongodb" %}
from {{ project_name }}.entity.base_entity import Entity

class {{ entity_name }}(Entity):
    def __init__(self):
        super().__init__("{{ table_name }}")

{% else %}
from sqlalchemy import Column, Integer, String, Boolean, Float, Text{% if has_date %}, Date{% endif %}{% if has_datetime %}, DateTime{% endif %}{% if has_fk %}, ForeignKey{% endif %}

from sqlalchemy.orm import relationship
from {{ project_name }}.entity.base_entity import Entity

class {{ entity_name }}(Base, Entity):
    __tablename__ = "{{ table_name }}"
    id = Column(Integer, primary_key=True, index=True)
{% for field in fields %}
{% if field.foreign_key %}
    {{ field.fk_column }} = Column(Integer, ForeignKey("{{ field.fk_table }}.id"), nullable=True)
    {{ field.name }} = relationship("{{ field.foreign_key }}", back_populates="{{ table_name }}")
{% else %}
    _{{ field.name }} = Column("{{ field.name }}", Text, nullable=True)
{% endif %}
{% endfor %}

    def __init__(self, db=None, **kwargs):
        Entity.__init__(self, "{{ entity_name }}", db=db, sql_model={{ entity_name }})
        # Filter kwargs to only include columns valid for the model
        valid_kwargs = {k: v for k, v in kwargs.items() if k in self.__table__.columns.keys() or hasattr(self, k)}
        super().__init__(**valid_kwargs)

{% for field in fields %}
{% if field.encrypt %}
    @property
    def {{ field.name }}(self):
        return decrypt_value(self._{{ field.name }})

    @{{ field.name }}.setter
    def {{ field.name }}(self, value: str):
        self._{{ field.name }} = encrypt_value(value)

{% elif field.hash %}
    @property
    def {{ field.name }}(self):
        return self._{{ field.name }}

    @{{ field.name }}.setter
    def {{ field.name }}(self, value: str):
        self._{{ field.name }} = hash_value(value)

{% elif not field.foreign_key %}
    @property
    def {{ field.name }}(self):
        return self._{{ field.name }}

    @{{ field.name }}.setter
    def {{ field.name }}(self, value):
        self._{{ field.name }} = value

{% endif %}
{% endfor %}
    def __repr__(self):
        return f"<{{ entity_name }} id={self.id}>"
{% endif %}
