services:
  api:
    build:
      context: .
      dockerfile: dockerfiles/Dockerfile.api
    ports:
      - "8000:8000"
    env_file: .env
    volumes:
      - ./data:/app/data
      - ./logs:/app/logs

  app:
    build:
      context: .
      dockerfile: dockerfiles/Dockerfile.app
    ports:
      - "8501:8501"
    env_file: .env
    depends_on:
      - api
    environment:
      - API_URL=http://api:8000
