from loguru import logger
from decouple import config
from pymongo import MongoClient
import pandas as pd
from sqlalchemy import create_engine
from apscheduler.schedulers.blocking import BlockingScheduler

# Config
{% if source == 'mongodb' %}
MONGO_URI = config("MONGO_URI", default="mongodb://localhost:27017")
MONGO_DB = config("MONGO_DB", default="{{ project_name }}")
{% elif source == 'api' %}
API_URL = config("API_URL", default="https://api.example.com/data")
API_KEY = config("API_KEY", default="")
{% endif %}

{% if dest == 'postgres' %}
POSTGRES_URI = config("POSTGRES_URI", default="postgresql://user:password@localhost:5432/{{ project_name }}")
{% elif dest == 'upstash' %}
UPSTASH_VECTOR_URL = config("UPSTASH_VECTOR_REST_URL")
UPSTASH_VECTOR_TOKEN = config("UPSTASH_VECTOR_REST_TOKEN")
{% endif %}

# Define which collections/endpoints to sync
SYNC_TARGETS = [
    # "users", 
    # "posts"
]

def sync_data():
    logger.info(f"Starting ELT sync: {{ source }} -> {{ dest }}")
    try:
        # Source Connection
        {% if source == 'mongodb' %}
        mongo_client = MongoClient(MONGO_URI)
        db = mongo_client[MONGO_DB]
        {% elif source == 'api' %}
        import requests
        {% endif %}
        
        # Destination Connection
        {% if dest == 'postgres' %}
        engine = create_engine(POSTGRES_URI)
        {% elif dest == 'upstash' %}
        from upstash_vector import Index
        index = Index(url=UPSTASH_VECTOR_URL, token=UPSTASH_VECTOR_TOKEN)
        {% endif %}
        
        for target in SYNC_TARGETS:
            logger.info(f"Extracting '{target}' from {{ source }}...")
            
            # Extraction Logic
            {% if source == 'mongodb' %}
            cursor = db[target].find({})
            df = pd.DataFrame(list(cursor))
            if "_id" in df.columns:
                df["_id"] = df["_id"].astype(str)
            {% elif source == 'api' %}
            # Example API extraction
            response = requests.get(f"{API_URL}/{target}", headers={"Authorization": f"Bearer {API_KEY}"})
            data = response.json()
            df = pd.DataFrame(data)
            {% endif %}
            
            if df.empty:
                logger.info(f"Target '{target}' is empty. Skipping.")
                continue
                
            logger.info(f"Loading {len(df)} records into {{ dest }}...")
            
            # Loading Logic
            {% if dest == 'postgres' %}
            df.to_sql(name=target, con=engine, if_exists="replace", index=False)
            {% elif dest == 'upstash' %}
            # Upstash Vector indexing (requires embedding logic usually, here we mock it or assume pre-embedded)
            # For a real implementation, we would use an embedding model here.
            # Example:
            # from langchain_openai import OpenAIEmbeddings
            # embeddings = OpenAIEmbeddings()
            # for i, row in df.iterrows():
            #     index.upsert(vectors=[(str(i), embeddings.embed_query(row['text']), {"text": row['text']})])
            logger.warning("Upstash Vector sync requires embedding logic. Please implement it in the loop below.")
            {% endif %}
            
            logger.info(f"Successfully synced '{target}'.")

        logger.info("Sync completed successfully.")

    except Exception as e:
        logger.error(f"Sync failed: {e}")
    finally:
        {% if source == 'mongodb' %}
        mongo_client.close()
        {% endif %}
        {% if dest == 'postgres' %}
        engine.dispose()
        {% endif %}

if __name__ == "__main__":
    # To run immediately:
    # sync_data()
    
    # To run on a schedule (e.g. every hour):
    logger.info("Starting ELT Scheduler...")
    scheduler = BlockingScheduler()
    scheduler.add_job(sync_data, 'interval', hours=1)
    
    try:
        scheduler.start()
    except (KeyboardInterrupt, SystemExit):
        pass
