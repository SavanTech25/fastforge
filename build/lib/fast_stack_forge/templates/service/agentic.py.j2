import os
from typing import Literal
from langchain_core.messages import HumanMessage
from langchain_core.tools import tool
from langgraph.graph import StateGraph, MessagesState, START, END
from langgraph.prebuilt import ToolNode

{% if provider in ['openai', 'azure'] %}
from langchain_openai import ChatOpenAI
{% elif provider == 'anthropic' %}
from langchain_anthropic import ChatAnthropic
{% elif provider == 'mistral' %}
from langchain_mistralai import ChatMistralAI
{% elif provider == 'gemini' %}
from langchain_google_genai import ChatGoogleGenerativeAI
{% endif %}

@tool
def add_tool(a: int, b: int) -> int:
    """Add two numbers."""
    return a + b

class {{ service_name }}Service:
    def __init__(self):
        {% if provider == 'openai' %}
        self.llm = ChatOpenAI(model="gpt-4o", temperature=0)
        {% elif provider == 'azure' %}
        self.llm = ChatOpenAI(model="gpt-4o", temperature=0, azure_deployment="gpt-4o", api_version="2024-02-15-preview")
        {% elif provider == 'anthropic' %}
        self.llm = ChatAnthropic(model="claude-3-5-sonnet-20240620", temperature=0)
        {% elif provider == 'mistral' %}
        self.llm = ChatMistralAI(model="mistral-large-latest", temperature=0)
        {% elif provider == 'gemini' %}
        self.llm = ChatGoogleGenerativeAI(model="gemini-1.5-pro", temperature=0)
        {% endif %}
        
        self.tools = [add_tool]
        self.llm_with_tools = self.llm.bind_tools(self.tools)
        self.agent = self._build_graph()

    def _build_graph(self):
        # 1. Define nodes
        async def llm_call(state: MessagesState):
            messages = state["messages"]
            response = await self.llm_with_tools.ainvoke(messages)
            return {"messages": [response]}
            
        tool_node = ToolNode(self.tools)

        # 2. Define routing logic
        def should_continue(state: MessagesState) -> Literal["tool_node", "__end__"]:
            messages = state["messages"]
            last_message = messages[-1]
            if last_message.tool_calls:
                return "tool_node"
            return END

        # 3. Build graph
        builder = StateGraph(MessagesState)
        builder.add_node("llm_call", llm_call)
        builder.add_node("tool_node", tool_node)
        
        builder.add_edge(START, "llm_call")
        builder.add_conditional_edges("llm_call", should_continue, ["tool_node", END])
        builder.add_edge("tool_node", "llm_call")
        
        return builder.compile()

    async def invoke(self, query: str, session_id: str = None) -> str:
        messages = [HumanMessage(content=query)]
        # If you need memory, pass config={"configurable": {"thread_id": session_id}} to ainvoke
        result = await self.agent.ainvoke({"messages": messages})
        return result["messages"][-1].content
