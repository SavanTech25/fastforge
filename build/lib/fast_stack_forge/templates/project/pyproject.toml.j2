[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "Generated by FastForge ⚡"
readme = "README.md"
requires-python = ">=3.10"
dependencies = [
{% for req in requirements %}
    "{{ req }}",
{% endfor %}
]

[tool.setuptools.packages.find]
where = ["src"]
include = ["*"]
